<%= form_with(model: nombre, local: true) do |form| %>
  <% if nombre.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(nombre.errors.count, "errores") %> impidieron guardar la tesis:</h2>

      <ul>
        <% nombre.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :titulo, "Título", style: "display: block" %>
    <%= form.text_field :titulo %>
  </div>

  <div>
    <%= form.label :descripcion, "Descripción", style: "display: block" %>
    <%= form.textarea :descripcion %>
  </div>

  <h3>Integrantes</h3>

  <%= form.fields_for :integrantes do |i| %>
    <div>
      <%= i.label :nombre, "Nombre del integrante" %>
      <%= i.text_field :nombre %>
    </div>
  <% end %>

  <hr>

  <h3>Asesores</h3>

  <%= form.fields_for :asesores do |a| %>
    <div>
      <%= a.label :nombre, "Nombre del asesor" %>
      <%= a.text_field :nombre %>
    </div>
  <% end %>

  <hr>

  <h3>Documento</h3>

  <div>
    <%= form.label :documento, "Subir documento" %>
    <%= form.file_field :documento %>
  </div>

  <hr>
  
  <div>
    <%= form.submit "Guardar Tesis" %>
  </div>
<% end %>