<!DOCTYPE html>
<html>
  <head>
    <title>TesisApp</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>

    <nav class="navbar">
      <h2 class="logo">
        Sistema de gestion de tesis de Ingeniería en Sistemas Computacionales
        <small>Universidad Tres Culturas</small>
      </h2>

      <div class="menu">

        <%= link_to "Inicio", root_path, class: "btn" %>

        <% unless controller_name == "sesiones" %>

          <div class="dropdown">
            <button class="btn">Menú</button>

            <div class="dropdown-content">

              <% if session[:rol] == "alumno" %>

                <% unless session[:tiene_tesis] %>
                  <%= link_to "Agregar Tesis", new_nombre_path %>
                <% end %>

                <%= link_to "Revisar Tesis", revisar_nombres_path %>

              <% elsif session[:rol] == "asesor" %>

                <%= link_to "Buscar", buscar_nombres_path %>
                <%= link_to "Historial de cambios", historial_path %>
                <%= link_to "Ver listado de Tesis", nombres_path %>

              <% else %>

                <%= link_to "Agregar Tesis", new_nombre_path %>
                <%= link_to "Buscar", buscar_nombres_path %>
                <%= link_to "Ver listado de Tesis", nombres_path %>
                <%= link_to "Historial de cambios", historial_path %>

              <% end %>

            </div>
          </div>

        <% end %>

        <% if session[:rol].present? %>
          <%= link_to "Cerrar sesión", logout_path, class: "btn" %>
        <% else %>
          <%= link_to "Iniciar sesión", login_path, class: "btn" %>
        <% end %>

      </div>
    </nav>

    <div class="contenedor">
      <%= yield %>
    </div>

    <div class="footer-logo">
      <img src="<%= asset_path('utc.png') %>" alt="UTC Logo">
    </div>

  </body>
</html>